# Database Configuration
# When running with docker-compose, this points to the 'db' service:
DATABASE_URL=postgresql://postgres:password@db:5432/proactive_budgeting

# If you are running uvicorn LOCALLY without Docker, use localhost instead:
# DATABASE_URL=postgresql://postgres:Password1@localhost:5432/proactive_budgeting

# JWT Configuration
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-string

# Cookie Auth Configuration
# Use true in production behind HTTPS.
COOKIE_SECURE=false
# Typical values: lax, strict, none
COOKIE_SAMESITE=lax
# Leave empty for localhost. Set in production if needed (e.g. .example.com)
COOKIE_DOMAIN=
ACCESS_COOKIE_NAME=access_token
REFRESH_COOKIE_NAME=refresh_token

# For credentialed requests, wildcard origins are not allowed.
# Must be a JSON list for pydantic-settings list parsing.
CORS_ALLOW_ORIGINS=["http://localhost:5173", "http://127.0.0.1:5173"]

